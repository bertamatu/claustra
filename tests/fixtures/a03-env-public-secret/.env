# Synthetic, non-functional values used only to exercise claustra's a03 rule.
# These are NOT real credentials.

# Violations — should be flagged.
# (Stripe-shaped values are tested separately via runtime construction so
# this file does not trip GitHub's secret-scanning push protection.)
NEXT_PUBLIC_OPENAI=sk-proj-ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789ABCD
NEXT_PUBLIC_TOKEN=YWJjZGVmZ2hpamtsbW5vcHFyc3R1dnd4eXowMTIzNDU2Nzg5

# Non-violations — should NOT be flagged:
NEXT_PUBLIC_STRIPE_PK=pk_test_ABCDEFGHIJKLMNOPQRSTUVWXYZ
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_PLACEHOLDER=<your-key-here>

# Non-public secret — out of scope for a03 (a01 covers reads of these from
# client code; a03 only flags NEXT_PUBLIC_* names).
DATABASE_URL=postgres://user:pw@host/db
